APP_GREETER_PROVIDER=fake
APP_GREETER_BASE_URL=
APP_REQUEST_TIMEOUT=5.0
APP_RETRY_ATTEMPTS=2
APP_ALLOWED_LOCALES=["en","fr"]
APP_MAX_RECIPIENT_LENGTH=128

# RAG — defaults run fully offline (fake embedder + reranker + generator).
APP_EMBEDDER_PROVIDER=fake
APP_GENERATOR_PROVIDER=fake
APP_RERANKER_PROVIDER=fake
APP_EMBEDDING_DIMENSIONS=256
APP_CHUNK_SIZE=512
APP_CHUNK_OVERLAP=64
APP_RETRIEVAL_CANDIDATES=20
APP_RETRIEVAL_TOP_K=4
# Required when APP_EMBEDDER_PROVIDER=voyage (install: uv sync --extra rag)
APP_VOYAGE_API_KEY=
APP_VOYAGE_MODEL=voyage-3
# Required when APP_GENERATOR_PROVIDER=claude (or set ANTHROPIC_API_KEY)
APP_ANTHROPIC_API_KEY=
APP_GENERATOR_MODEL=claude-opus-4-8
APP_GENERATOR_MAX_TOKENS=1024
# Required when APP_RERANKER_PROVIDER=cohere (or set CO_API_KEY)
APP_COHERE_API_KEY=
APP_RERANK_MODEL=rerank-v3.5
